# ============================================================================
# CONFIGURACIÓN DE HIPERFORGE USER
# ============================================================================
# 
# Este archivo define todas las variables de entorno disponibles para 
# HiperForge User. Cópialo a .env y ajusta según tu entorno.
#
# Orden de precedencia (mayor a menor):
#   1. Variables de entorno (FORGE_USER__)
#   2. Archivo .env en el directorio de trabajo
#   3. Archivo .env en ~/.hiperforge_user/
#   4. Valores por defecto en forge_core/config/schema.py
# ============================================================================
# SUBSISTEMA LLM
# ============================================================================
# Provider LLM por defecto: "openai", "anthropic" o "local"
# Default: "anthropic"
FORGE_USER__LLM__DEFAULT_PROVIDER=anthropic
# Provider alternativo en caso de fallos del principal (opcional)
# FORGE_USER__LLM__FALLBACK_PROVIDER=openai
# --- OpenAI Configuration ---
# API key de OpenAI (requerida si DEFAULT_PROVIDER=openai)
# Obtén la clave en: https://platform.openai.com/api-keys
# FORGE_USER__LLM__OPENAI_API_KEY=sk-...
# Modelo de OpenAI a usar
# Default: "gpt-4o"
# FORGE_USER__LLM__OPENAI_MODEL=gpt-4o
# URL base del API de OpenAI (para proxies o Azure OpenAI)
# Default: "https://api.openai.com/v1"
# FORGE_USER__LLM__OPENAI_BASE_URL=https://api.openai.com/v1
# --- Anthropic Configuration ---
# API key de Anthropic (requerida si DEFAULT_PROVIDER=anthropic)
# Obtén la clave en: https://console.anthropic.com/
# FORGE_USER__LLM__ANTHROPIC_API_KEY=sk-ant-...
# Modelo de Anthropic a usar
# Default: "claude-sonnet-4-20250514"
# FORGE_USER__LLM__ANTHROPIC_MODEL=claude-sonnet-4-20250514
# URL base del API de Anthropic
# Default: "https://api.anthropic.com"
# FORGE_USER__LLM__ANTHROPIC_BASE_URL=https://api.anthropic.com
# --- Modelo Local (Ollama) ---
# URL del servidor Ollama para inferencia local
# Default: "http://localhost:11434"
# FORGE_USER__LLM__LOCAL_MODEL_URL=http://localhost:11434
# Nombre del modelo cargado en Ollama
# Default: "llama3.2"
# FORGE_USER__LLM__LOCAL_MODEL_NAME=llama3.2
# --- Parámetros de Generación ---
# Máximo de tokens en la respuesta del LLM
# Default: 4096
# FORGE_USER__LLM__MAX_TOKENS_RESPONSE=4096
# Temperatura de muestreo (0.0-2.0)
# Valores bajos (0.1-0.4) para tareas precisas
# Valores altos para creatividad
# Default: 0.3
# FORGE_USER__LLM__TEMPERATURE=0.3
# Tamaño máximo del context window del modelo
# Default: 128000
# FORGE_USER__LLM__CONTEXT_WINDOW_TOKENS=128000
# --- Timeouts y Reintentos ---
# Timeout máximo para una request al LLM API (segundos)
# Default: 60.0
# FORGE_USER__LLM__REQUEST_TIMEOUT_SECONDS=60.0
# Número máximo de reintentos ante errores transitorios
# Default: 3
# FORGE_USER__LLM__MAX_RETRIES=3
# Delay base para backoff exponencial entre reintentos (segundos)
# Default: 1.0
# FORGE_USER__LLM__RETRY_BASE_DELAY_SECONDS=1.0
# Delay máximo entre reintentos (segundos)
# Default: 30.0
# FORGE_USER__LLM__RETRY_MAX_DELAY_SECONDS=30.0
# --- Streaming ---
# Habilitar streaming de respuestas (true/false)
# Default: true
# FORGE_USER__LLM__ENABLE_STREAMING=true
# ============================================================================
# SUBSISTEMA DE ALMACENAMIENTO
# ============================================================================
# Directorio raíz para todos los datos persistidos
# Se crea automáticamente si no existe
# Default: ~/.hiperforge_user/data
# FORGE_USER__STORAGE__DATA_DIR=~/.hiperforge_user/data
# Nombre del archivo SQLite principal
# Default: "forge_user.db"
# FORGE_USER__STORAGE__DATABASE_FILENAME=forge_user.db
# Nombre del archivo SQLite para audit log
# Default: "forge_audit.db"
# FORGE_USER__STORAGE__AUDIT_DATABASE_FILENAME=forge_audit.db
# Timeout para adquirir conexión a SQLite (segundos)
# Default: 30.0
# FORGE_USER__STORAGE__CONNECTION_TIMEOUT_SECONDS=30.0
# Habilitar WAL (Write-Ahead Logging) en SQLite
# Default: true
# FORGE_USER__STORAGE__WAL_MODE=true
# Tamaño del cache de páginas SQLite
# 10000 páginas ≈ 40MB de cache
# Default: 10000
# FORGE_USER__STORAGE__CACHE_SIZE_PAGES=10000
# Tamaño del memory-mapped I/O para SQLite en bytes
# Default: 268435456 (256 MB)
# FORGE_USER__STORAGE__MMAP_SIZE_BYTES=268435456
# Habilitar VACUUM automático
# Default: true
# FORGE_USER__STORAGE__AUTO_VACUUM=true
# Habilitar backups automáticos
# Default: true
# FORGE_USER__STORAGE__BACKUP_ENABLED=true
# Intervalo entre backups automáticos (horas)
# Default: 24
# FORGE_USER__STORAGE__BACKUP_INTERVAL_HOURS=24
# Número máximo de archivos de backup a conservar
# Default: 7
# FORGE_USER__STORAGE__MAX_BACKUP_FILES=7
# Días de retención para sesiones cerradas
# Default: 90
# FORGE_USER__STORAGE__SESSION_RETENTION_DAYS=90
# Días de retención para entradas del audit log
# Default: 365
# FORGE_USER__STORAGE__AUDIT_RETENTION_DAYS=365
# ============================================================================
# SUBSISTEMA DE SEGURIDAD
# ============================================================================
# Directorios donde el agente puede leer y escribir archivos
# Las rutas se especifican separadas por ";" (en Windows) o ":" (Unix)
# Default: $HOME, $HOME/Documents, $HOME/Downloads, $HOME/Desktop
# FORGE_USER__SECURITY__ALLOWED_DIRECTORIES=/home/user:/home/user/Documents
# Patrones glob de rutas nunca accesibles
# Bloqueadas a nivel de policy engine
# FORGE_USER__SECURITY__BLOCKED_PATH_PATTERNS=**/.ssh/*;**/.gnupg/*;**/.*secret*
# Tamaño máximo de archivo que el agente puede leer (MB)
# Default: 50
# FORGE_USER__SECURITY__MAX_FILE_SIZE_MB=50
# Tamaño máximo de archivo que el agente puede escribir (MB)
# Default: 10
# FORGE_USER__SECURITY__MAX_FILE_WRITE_SIZE_MB=10
# Aplicaciones que el agente puede lanzar sin aprobación
# Lista separada por ";" (Windows) o ":" (Unix)
# Default: firefox, google-chrome, libreoffice, code, etc.
# FORGE_USER__SECURITY__APP_ALLOWLIST=firefox;google-chrome;code
# Habilitar acceso al portapapeles
# Default: false (false por privacidad)
# FORGE_USER__SECURITY__CLIPBOARD_ACCESS_ENABLED=false
# Permitir tomar screenshots del escritorio
# Default: true
# FORGE_USER__SECURITY__SCREENSHOT_ENABLED=true
# Tiempo máximo de espera para una aprobación del usuario (segundos)
# Default: 300.0
# FORGE_USER__SECURITY__APPROVAL_TIMEOUT_SECONDS=300.0
# Recordar decisiones de aprobación (true/false)
# Default: true
# FORGE_USER__SECURITY__REMEMBER_APPROVALS=true
# Timeout máximo para operaciones en proceso sandbox (segundos)
# Default: 30.0
# FORGE_USER__SECURITY__SANDBOX_TIMEOUT_SECONDS=30.0
# Ejecutar acciones de desktop en proceso sandbox separado
# Default: true
# FORGE_USER__SECURITY__SANDBOX_ENABLED=true
# Límite de invocaciones de tools por minuto
# Default: 60
# FORGE_USER__SECURITY__MAX_TOOL_CALLS_PER_MINUTE=60
# Límite de requests web (search + fetch) por minuto
# Default: 30
# FORGE_USER__SECURITY__MAX_WEB_REQUESTS_PER_MINUTE=30
# Dominios web permitidos para búsqueda y fetch
# "*" permite todos, lista separada por ";" (Windows) o ":" (Unix)
# Default: "*"
# FORGE_USER__SECURITY__ALLOWED_DOMAINS=*
# Dominios web explícitamente bloqueados
# Lista separada por ";" (Windows) o ":" (Unix)
# FORGE_USER__SECURITY__BLOCKED_DOMAINS=
# ============================================================================
# SUBSISTEMA DE OBSERVABILIDAD
# ============================================================================
# Nivel mínimo de log a emitir
# Valores: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# FORGE_USER__OBSERVABILITY__LOG_LEVEL=INFO
# Formato de los logs
# Valores: "json" (producción), "console" (desarrollo)
# Default: "console"
# FORGE_USER__OBSERVABILITY__LOG_FORMAT=console
# Directorio donde se almacenan los archivos de log
# Default: ~/.hiperforge_user/logs
# FORGE_USER__OBSERVABILITY__LOG_DIR=~/.hiperforge_user/logs
# Nombre del archivo de log principal
# Default: "forge_user.log"
# FORGE_USER__OBSERVABILITY__LOG_FILENAME=forge_user.log
# Tamaño máximo del archivo de log antes de rotar (MB)
# Default: 100
# FORGE_USER__OBSERVABILITY__LOG_MAX_SIZE_MB=100
# Número de archivos de log anteriores a conservar
# Default: 5
# FORGE_USER__OBSERVABILITY__LOG_BACKUP_COUNT=5
# Exporter de trazas OpenTelemetry
# Valores: "none" (testing), "console" (desarrollo), "otlp" (producción)
# Default: "none"
# FORGE_USER__OBSERVABILITY__TRACING_EXPORTER=none
# URL del collector OpenTelemetry (si TRACING_EXPORTER=otlp)
# Ejemplo: http://localhost:4317 (gRPC) o http://localhost:4318 (HTTP)
# FORGE_USER__OBSERVABILITY__OTLP_EXPORTER_URL=http://localhost:4317
# Protocolo OTLP a usar: "grpc" o "http"
# Default: "grpc"
# FORGE_USER__OBSERVABILITY__OTLP_PROTOCOL=grpc
# Métricas habilitadas (true/false)
# Default: true
# FORGE_USER__OBSERVABILITY__METRICS_ENABLED=true
# ============================================================================
# SUBSISTEMA DE BÚSQUEDA WEB
# ============================================================================
# API key de Tavily Search (si se usa búsqueda web)
# Obtén la clave en: https://app.tavily.com
# FORGE_USER__SEARCH__TAVILY_API_KEY=tvly-...
# Número máximo de resultados de búsqueda por query
# Default: 10
# FORGE_USER__SEARCH__MAX_RESULTS=10
# Timeout máximo para una búsqueda (segundos)
# Default: 15.0
# FORGE_USER__SEARCH__REQUEST_TIMEOUT_SECONDS=15.0
# ============================================================================
# SUBSISTEMA DE POLÍTICA
# ============================================================================
# Política de aprobación: "strict", "balanced", "permissive"
# Default: "balanced"
# FORGE_USER__POLICY__APPROVAL_STRATEGY=balanced
# Nivel de severidad mínima para requerir aprobación
# Valores: "low", "medium", "high", "critical"
# Default: "medium"
# FORGE_USER__POLICY__MIN_APPROVAL_SEVERITY=medium
# Habilitar auditoría de todos los eventos
# Default: true
# FORGE_USER__POLICY__AUDIT_ENABLED=true
# ============================================================================
# CONFIGURACIÓN GENERAL DEL SISTEMA
# ============================================================================
# Versión de esquema de configuración (para migraciones futuras)
# Default: "1.0.0"
# FORGE_USER__VERSION=1.0.0
# Modo de depuración (true/false)
# Default: false
# FORGE_USER__DEBUG=false
